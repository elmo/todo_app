module Api
  module V1
    class Api::V1::TodosController < ApplicationController
      before_action :authenticate_by_jwt
      before_action :get_todo, only: [ :update, :destroy ]
      skip_before_action :verify_authenticity_token
      def index
        @todos = @user.todos.order(created_at: :desc)
        render json: @todos
      end

      def create
        @todo = @user.todos.new(todo_params)
        if @todo.save
          render json: @todo, status: :created
        else
          render json: @todo.errors, status: :unprocessable_entity
        end
      end

      def update
        @todo = @user.todos.find(params[:id])
        @todo.update(todo_params)
        render json: @todo
      end

      def destroy
        @todo = @user.todos.find(params[:id]).destroy
        head :no_content
      end

      private

      def authenticate_by_jwt
          token = session[:jwt]
          #token = request.headers["Authorization"].to_s.split(" ").last
          return unless token

          decoded_token = ::JWTService.decode(token)
          @user = User.find(decoded_token[0]["user_id"])
      end

      def todo_params
        params.require(:todo).permit(:title, :completed)
      end
    end
  end
end
